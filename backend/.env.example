# Copy to .env and adjust. See README for full setup.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_this_to_something_more_secure_in_production
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root:password@127.0.0.1:3306/posutki_db?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
# Dev: broad regex. In production set a narrow origin in .env.local / server env.
CORS_ALLOW_ORIGIN='^https?://[^/]+(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me
###< lexik/jwt-authentication-bundle ###

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
MAILER_FROM="noreply@example.com"
ADMIN_EMAILS=["admin@example.com"]
###< symfony/mailer ###

FRONTEND_URL=http://localhost:3000

# SMS rate limits (abuse prevention; used by DoctrineSmsRateLimiter)
SMS_PHONE_COOLDOWN_SECONDS=60
SMS_PER_IP_DAILY_LIMIT=5
SMS_PER_IP_UNIQUE_PHONES_DAILY=3
SMS_GLOBAL_DAILY_LIMIT=300

# reCAPTCHA v2 (server verifies token from frontend on /api/auth/sms/request and /api/contact)
RECAPTCHA_ENABLED=0
RECAPTCHA_SECRET=

# RocketSMS (production SMS provider; dev uses StubSmsService)
ROCKETSMS_USERNAME=
ROCKETSMS_PASSWORD=
ROCKETSMS_SENDER=
ROCKETSMS_VERIFICATION_TEMPLATE="Ваш код подтверждения: %s"

# Next.js on-demand revalidation
NEXTJS_REVALIDATE_URL=
NEXTJS_REVALIDATION_SECRET=
