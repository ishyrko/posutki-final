DirectoryIndex index.php

# EasyAdmin (/admin): HTTP Basic before Symfony login. File: backend/config/.htpasswd (see .htpasswd.example).
# Do not use <If> here — it causes 500 on many cPanel/Apache setups.
<IfModule mod_authn_file.c>
    <IfModule mod_authz_core.c>
        <IfModule mod_setenvif.c>
            SetEnvIf Request_URI "!^/admin" ADMIN_SKIP_BASIC_AUTH
        </IfModule>
        AuthType Basic
        AuthName "Restricted"
        AuthUserFile ../config/.htpasswd
        <RequireAny>
            Require env ADMIN_SKIP_BASIC_AUTH
            Require valid-user
        </RequireAny>
    </IfModule>
</IfModule>

<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Uploaded files must be served as static assets, never via index.php (cPanel/shared hosting).
    RewriteRule ^uploads/ - [L]

    RewriteCond %{REQUEST_URI}::$0 ^(/.+)/(.*)::\2$
    RewriteRule .* - [E=BASE:%1]

    RewriteCond %{HTTP:Authorization} .+
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%0]

    RewriteCond %{ENV:REDIRECT_STATUS} =""
    RewriteRule ^index\.php(?:/(.*)|$) %{ENV:BASE}/index.php [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ %{ENV:BASE}/index.php [L]
</IfModule>
