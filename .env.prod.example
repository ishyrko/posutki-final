# Copy to .env.prod and fill in before: make prod-full
#
# Co-deploy with rnb-upstream on the same server (recommended):
#   1. Leave PROD_ENABLE_EDGE_PROXY unset (or 0) — do NOT bind :80/:443 here.
#   2. Deploy: make prod-full
#   3. In rnb-by: set POSUTKI_SSL_CERT_* in .env.prod, then make prod-posutki-edge-reload
#      (see docker-compose.posutki-edge.yml and docker/nginx/edge-posutki.conf).
#   4. Use a separate MySQL database/user (see DATABASE_URL).
#
# Standalone server (only posutki on the host):
#   PROD_ENABLE_EDGE_PROXY=1
#   make prod-edge-full

COMPOSE_PROJECT_NAME=posutki

# App nginx on the host (for rnb shared edge). Change port if 9080 is taken.
APP_HTTP_BIND=127.0.0.1:9080

# Built-in TLS terminator (:80/:443) — only when PROD_ENABLE_EDGE_PROXY=1
PROD_ENABLE_EDGE_PROXY=0
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443
SSL_CERT_FULLCHAIN_PATH=/absolute/path/to/posutki-fullchain.pem
SSL_CERT_PRIVKEY_PATH=/absolute/path/to/posutki-privkey.pem
BASIC_AUTH_HTPASSWD_PATH=/absolute/path/to/posutki.htpasswd

# Symfony
APP_SECRET=change_this_to_a_random_32_char_string
DATABASE_URL=mysql://posutki_user:secret@host.docker.internal:3306/posutki_db?serverVersion=8.0&charset=utf8mb4
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
CORS_ALLOW_ORIGIN=^https?://(www\.)?posutki\.by$
FRONTEND_URL=https://posutki.by
MAILER_DSN=smtp://user:password@smtp.example.com:587
MAILER_FROM="posutki.by <noreply@posutki.by>"
ADMIN_EMAILS=["admin@posutki.by"]
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Google OAuth (shared between backend and frontend)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google reCAPTCHA v2
RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key
RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET=your_recaptcha_v2_secret_key

# Next.js (baked into the frontend image at build time)
NEXT_PUBLIC_API_URL=https://posutki.by/api
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your_yandex_maps_api_key

# ISR revalidation (backend → Next.js /revalidate)
NEXTJS_REVALIDATION_SECRET=change_to_a_long_random_string
NEXTJS_REVALIDATE_URL=http://frontend:3000/revalidate
BACKEND_INTERNAL_URL=http://nginx
