# posutki.by behind the rnb-upstream edge reverse-proxy
#
# In the rnb-by repo (on the server) this is already packaged as:
#   - docker/nginx/edge-posutki.conf
#   - docker-compose.posutki-edge.yml
#   - make prod-posutki-edge-reload
#
# Steps:
#   1. Deploy posutki: cp .env.prod.example .env.prod && make prod-full
#   2. In rnb-by .env.prod set POSUTKI_SSL_CERT_* paths (Let's Encrypt for posutki.by)
#   3. In rnb-by: make prod-posutki-edge-reload
#   4. curl -sI https://posutki.by/  and  curl -sI http://127.0.0.1:9080/
#
# If you maintain nginx by hand, use the blocks below (same as edge-posutki.conf).

upstream posutki_app {
    server host.docker.internal:9080;
    keepalive 8;
}

# ... see rnb-by/docker/nginx/edge-posutki.conf for full server blocks
